{
    "name": "atldays/laravel-eloquent-filters",
    "description": "Advanced Laravel models filtering capabilities",
    "keywords": [
        "atldays",
        "laravel",
        "laravel-eloquent-filters",
        "eloquent-filters",
        "model-filters"
    ],
    "homepage": "https://github.com/atldays/laravel-eloquent-filters",
    "license": "MIT",
    "authors": [{
        "name": "Anjey Tsibylskij",
        "homepage": "https://github.com/atldays",
        "role": "Maintainer"
    }],
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.9"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Atldays\\LaravelEloquentFilters\\": "src",
            "Atldays\\LaravelEloquentFilters\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atldays\\LaravelEloquentFilters\\Tests\\": "tests"
        }
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "test": "vendor/bin/phpunit --no-coverage",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Atldays\\LaravelEloquentFilters\\EloquentFiltersServiceProvider"
            ],
            "aliases": {}
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
